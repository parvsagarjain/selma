# Copy this file to `.env` and fill in your values (see WAITLIST-SHEET-SETUP.md).
# .env is gitignored so your real secrets never get committed.

# Google Apps Script Web App URL that receives each waitlist sign-up
SHEET_WEBHOOK_URL=

# Shared secret the Apps Script checks — must match SECRET in the script
SHEET_WEBHOOK_TOKEN=

# Secret that protects GET /api/waitlist (the admin peek at sign-ups). If left blank, that
# endpoint is DISABLED so a public deploy can't leak emails. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADMIN_TOKEN=
